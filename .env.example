# Copy to .env and adjust. The .env file is gitignored.
# docker compose reads these automatically.

# Grafana admin credentials (change for any non-local use).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Optional: real Alertmanager receivers -------------------------------
# Uncomment the matching blocks in alertmanager/alertmanager.yml to use these.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
# PAGERDUTY_ROUTING_KEY=your-pagerduty-events-v2-routing-key
